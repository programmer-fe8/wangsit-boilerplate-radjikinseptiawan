{
	"mcpServers": {
		"wangsvue-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"wangsvue-mcp",
				"run"
			],
			"alwaysAllow": [
				"list_all_components",
				"analyze_component",
				"resolve_type_definition"
			]
		},
		"wangsvue-docs": {
			"type": "streamable-http",
			"url": "https://wangsvue.netlify.app/mcp",
			"alwaysAllow": [
				"get-sections",
				"get-example",
				"list-components"
			]
		},
		"Figma Desktop": {
			"type": "streamable-http",
			"url": "http://127.0.0.1:3845/mcp",
			"alwaysAllow": [
				"get_design_context",
				"get_screenshot"
			]
		}
	}
}