{
  "name": "@fewangsit/mfe-boilerplate-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "microtsm e2e",
    "serve": "microtsm serve",
    "build": "tsc && microtsm build",
    "lint": "eslint . --fix",
    "format": "prettier . --write",
    "serve:https": "microtsm serve --https",
    "check-coverage": "lcov-total ./coverage/lcov.info",
