    "inspect-mcp": "npx @modelcontextprotocol/inspector npx wangsvue-mcp"
  },
  "dependencies": {
    "@fewangsit/eslint-config-vue-code-standard": "^1.0.12",
    "@fewangsit/wangsvue": "1.5.229-alpha.7",
    "@fewangsit/wangsvue-presets": "1.0.110-alpha.0",
    "@fewangsit/workspace-api-services": "1.0.18-alpha.1",
    "@microtsm/vue": "^0.0.22",
    "@vee-validate/yup": "^4.15.1",
    "@vueuse/core": "^14.1.0",
    "@wangs-ui/core": "^1.0.23",
    "@wangs-ui/vue": "^1.0.23",
    "axios": "1.8.4",
    "cypress": "13.13.2",
    "cypress-intercept-formdata": "^0.6.0",
    "microtsm": "^0.0.37",
    "pinia": "^2.1.7",
    "vee-validate": "^4.15.1",
    "vue": "3.5.16",
    "vue-router": "4.5.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@cypress/code-coverage": "3.14.0",
    "@cypress/vue": "6.0.1",
    "@microtsm/cli": "^0.0.83",
    "@types/mocha": "10.0.7",
    "@types/node": "22.15.19",
    "@vitejs/plugin-vue": "5.2.4",
    "autoprefixer": "10.4.20",
    "lcov-total": "2.1.1",
    "nyc": "15.1.0",
    "postcss": "^8.5.4",
    "prettier": "3.3.3",
    "start-server-and-test": "2.0.5",
    "tailwindcss": "3",
    "typescript": "5.8.3",
    "vite-plugin-istanbul": "6.0.2"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion": "2.0.2"
    }
